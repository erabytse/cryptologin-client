{
  "name": "cryptologin-client",
  "version": "1.2.4",
  "description": "Zero-storage authentication client SDK for CryptoLogin",
  "main": "dist/cryptologin-client.js",
  "module": "dist/cryptologin-client.esm.js",
  "browser": "dist/cryptologin-client.min.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/cryptologin-client.esm.js",
      "require": "./dist/cryptologin-client.js",
      "browser": "./dist/cryptologin-client.min.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "authentication",
    "security",
    "passwordless",
    "zero-knowledge",
    "encryption",
    "crypto",
    "hmac",
    "pbkdf2"
  ],
  "author": "erabytse",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/erabytse/cryptologin-client"
  },
  "bugs": {
    "url": "https://github.com/erabytse/cryptologin-client/issues"
  },
  "homepage": "https://github.com/erabytse/cryptologin-client#readme",
  "devDependencies": {
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@vitest/coverage-v8": "^1.6.0",
    "happy-dom": "^20.10.6",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "vitest": "^1.6.0"
  }
}
